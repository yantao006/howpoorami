/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'sha256-sP5FgghEwN/gLWItdAJJC3AZp2u0+jYKS6UoDekuf2A='; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'
  # CSP note: 'unsafe-inline' is still required because Next.js injects varying
  # inline hydration scripts per page that cannot be hashed ahead of time. The
  # sha256 hash explicitly allows our known theme-initialisation script from
  # layout.tsx. Once Next.js supports nonce-based CSP, 'unsafe-inline' can be
  # removed entirely.
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
